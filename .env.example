# MySQL (локально через Docker или Beget)
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=tasktracker
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=tasktracker
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Или одной строкой (Beget / production):
# DATABASE_URL=mysql://tasktracker:password@host.beget.tech:3306/tasktracker

# Telegram
BOT_TOKEN=
WEBAPP_URL=http://localhost:8000

# App
DEBUG=true
LOG_LEVEL=INFO
ENV=development

# Production:
# ENV=production
# DEBUG=false
# WEBAPP_URL=https://your-domain.com
# CORS_ORIGINS=https://your-domain.com

# Optional
# DATA_DIR=./data
# SNAPSHOT_KEEP=10
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=480
# DB_CONNECT_TIMEOUT=10
# DB_READ_TIMEOUT=30
# DB_WRITE_TIMEOUT=30
