# Скопируйте на сервер: cp .env.beget.example .env

# --- Beget MySQL (пример gvoroz2u) ---
# С SSH на сервере:     mysql -h localhost -u gvoroz2u_db -p gvoroz2u_db
# Из Docker-контейнера: host.docker.internal (localhost внутри контейнера — это не MySQL!)
# С другой машины:      gvoroz2u.beget.tech
DATABASE_URL=mysql://gvoroz2u_db:ВАШ_ПАРОЛЬ@host.docker.internal:3306/gvoroz2u_db

# Telegram
BOT_TOKEN=123456789:ABC...
WEBAPP_URL=https://ваш-домен.ru

# Production (обязательно)
ENV=production
DEBUG=false
CORS_ORIGINS=https://ваш-домен.ru
LOG_LEVEL=INFO

# Runtime
DATA_DIR=/data
