# Скопируйте на сервер: cp .env.beget.example .env

# =============================================================================
# Режим A: Beget SHARED (mayday) — без Docker, deploy-beget-native.sh
# =============================================================================
DATABASE_URL=mysql://gvoroz2u_db:ВАШ_ПАРОЛЬ@localhost:3306/gvoroz2u_db

# =============================================================================
# Режим B: Beget VPS + Docker — deploy-beget.sh
# =============================================================================
# DATABASE_URL=mysql://gvoroz2u_db:ВАШ_ПАРОЛЬ@host.docker.internal:3306/gvoroz2u_db
# DATA_DIR=/data

# Telegram
BOT_TOKEN=123456789:ABC...
WEBAPP_URL=https://ваш-домен.ru

# Production (обязательно)
ENV=production
DEBUG=false
CORS_ORIGINS=https://ваш-домен.ru
LOG_LEVEL=INFO

# Для native-деплоя DATA_DIR не указывайте — будет ./data автоматически
